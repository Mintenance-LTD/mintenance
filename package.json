{
  "name": "@mintenance/monorepo",
  "version": "1.2.4",
  "private": true,
  "description": "Mintenance - Contractor Discovery Marketplace (Monorepo)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "npm run dev -w @mintenance/web",
    "dev:mobile": "npm run dev -w @mintenance/mobile",
    "build": "npm run build:packages && npm run build:apps",
    "build:packages": "npm run build -w @mintenance/types && npm run build -w @mintenance/shared && npm run build -w @mintenance/auth && npm run build -w @mintenance/design-tokens && npm run build -w @mintenance/api-client && npm run build -w @mintenance/security && npm run build -w @mintenance/shared-ui",
    "build:apps": "npm run build -w @mintenance/web && npm run build -w @mintenance/mobile",
    "build:web": "npm run build -w @mintenance/web",
    "build:mobile": "npm run build -w @mintenance/mobile",
    "start": "npm run start -w @mintenance/web",
    "start:web": "npm run start -w @mintenance/web",
    "start:mobile": "npm run start -w @mintenance/mobile",
    "lint": "npm run lint -w @mintenance/web && npm run lint -w @mintenance/mobile",
    "lint:web": "npm run lint -w @mintenance/web",
    "lint:mobile": "npm run lint -w @mintenance/mobile",
    "type-check": "npm run type-check -w @mintenance/web && npm run type-check -w @mintenance/mobile",
    "type-check:web": "npm run type-check -w @mintenance/web",
    "type-check:mobile": "npm run type-check -w @mintenance/mobile",
    "test": "npm run test -w @mintenance/web && npm run test -w @mintenance/mobile",
    "test:web": "npm run test -w @mintenance/web",
    "test:mobile": "npm run test -w @mintenance/mobile",
    "clean": "npm run clean -w @mintenance/web && npm run clean -w @mintenance/mobile",
    "clean:all": "rimraf node_modules apps/*/node_modules packages/*/node_modules",
    "reset": "npm run clean:all && npm install",
    "install:online": "npm install --no-offline",
    "deploy:verify": "node scripts/verify-deployment.js",
    "test:payment": "tsx apps/web/scripts/test-payment-flow.ts",
    "verify:database": "tsx apps/web/scripts/verify-database.ts",
    "validate:schema": "tsx apps/web/scripts/validate-schema-2025.ts",
    "test:gcp-auth": "tsx apps/web/scripts/test-gcp-auth.ts",
    "test:scripts": "jest --config scripts/jest.config.js",
    "create:gcp-buckets": "tsx apps/web/scripts/create-gcp-buckets.ts",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:ui": "playwright test --ui",
    "audit:use-client": "node scripts/audit-use-client.js",
    "audit:file-sizes": "node scripts/check-file-sizes.js",
    "audit:any-types": "node scripts/find-any-types.js",
    "audit:console": "node scripts/find-console-statements.js",
    "audit:all": "npm run audit:use-client && npm run audit:file-sizes && npm run audit:any-types && npm run audit:console",
    "migrate:yolo": "tsx apps/web/scripts/migrate-yolo-to-storage.ts",
    "migrate:yolo:dry": "tsx apps/web/scripts/migrate-yolo-to-storage.ts --dry-run",
    "sam3:auto-label": "tsx apps/web/scripts/sam3-auto-label.ts",
    "sam3:auto-label:test": "tsx apps/web/scripts/sam3-auto-label.ts --test",
    "sam3:auto-label:full": "tsx apps/web/scripts/sam3-auto-label.ts --full",
    "sam3:package-for-colab": "tsx apps/web/scripts/package-filtered-images-for-colab.ts",
    "merge-datasets-v4": "tsx apps/web/scripts/merge-datasets-v4.ts",
    "create-colab-zips-v4": "tsx apps/web/scripts/create-colab-zips-v4.ts",
    "verify:yolo-migration": "tsx apps/web/scripts/verify-yolo-migration.ts",
    "upload:yolo": "tsx apps/web/scripts/upload-yolo-to-storage.ts",
    "upload:yolo:help": "tsx apps/web/scripts/upload-yolo-to-storage.ts --help",
    "upload-onnx": "tsx apps/web/scripts/upload-onnx-model-to-supabase.ts",
    "test-onnx": "tsx apps/web/scripts/test-onnx-model-loading.ts",
    "migrate:setup": "tsx apps/web/scripts/create-exec-sql-function.ts",
    "migrate:push": "tsx apps/web/scripts/push-all-migrations-to-supabase.ts",
    "migrate:all": "npm run migrate:setup && npm run migrate:push",
    "test:load:ai-cache": "tsx apps/web/scripts/load-test-ai-cache.ts",
    "verify-task": "node scripts/verify-task-completion.js",
    "test:a11y": "node scripts/check-accessibility.js",
    "test:accessibility": "node scripts/check-accessibility.js"
  },
  "keywords": [
    "marketplace",
    "contractors",
    "react-native",
    "nextjs",
    "monorepo"
  ],
  "author": "Mintenance Team",
  "license": "MIT",
  "engines": {
    "node": ">=20.19.4 <23.0.0",
    "npm": ">=9.0.0"
  },
  "devDependencies": {
    "@babel/generator": "^7.28.5",
    "@babel/parser": "^7.28.5",
    "@babel/traverse": "^7.28.5",
    "@babel/types": "^7.28.5",
    "@expo/metro-runtime": "~5.0.5",
    "@playwright/test": "^1.58.0",
    "@types/archiver": "^7.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.2.3",
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.8",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.3.3",
    "glob": "^13.0.0",
    "globby": "^14.0.2",
    "jest": "^29.7.0",
    "prettier": "^3.0.0",
    "qrcode": "^1.5.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native-worklets": "^0.5.1",
    "react-test-renderer": "19.1.0",
    "rimraf": "^5.0.5",
    "speakeasy": "^2.0.0",
    "tailwindcss": "^3.4.18",
    "ts-jest": "^29.4.5",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "@react-native/assets-registry": "0.81.5",
    "@react-native/babel-plugin-codegen": "0.81.5",
    "@react-native/babel-preset": "0.81.5",
    "@react-native/codegen": "0.81.5",
    "@react-native/debugger-frontend": "0.81.5",
    "@react-native/dev-middleware": "0.81.5",
    "@react-native/normalize-colors": "0.81.5",
    "@sentry/browser": "7.119.1",
    "@sentry/react": "7.119.1",
    "fast-xml-parser": "5.3.4"
  }
}
