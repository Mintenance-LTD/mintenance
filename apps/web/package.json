{
  "name": "@mintenance/web",
  "version": "1.2.3",
  "private": true,
  "description": "Mintenance Web App (Next.js)",
  "scripts": {
    "dev": "next dev -p 3000 --webpack",
    "dev:3001": "next dev -p 3001 --webpack",
    "dev:turbo": "next dev -p 3000 --turbo",
    "build": "npm run clean && next build --webpack",
    "build:packages": "echo 'Skipping package builds — webpack resolves from source via aliases in next.config.js'",
    "build:web": "next build --webpack",
    "build:analyze": "npm run clean && ANALYZE=true next build --webpack",
    "build:turbo": "npm run clean && next build",
    "start": "next start -p 3000",
    "lint": "eslint .",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:run": "vitest run",
    "test:parallel": "vitest run --reporter=verbose",
    "test:debug": "vitest --inspect-brk --no-file-parallelism",
    "test:redis": "ts-node lib/redis-validator.ts",
    "migrate": "ts-node lib/migration-runner.ts",
    "migrate:status": "npm run migrate status",
    "migrate:apply": "npm run migrate apply",
    "migrate:rollback": "npm run migrate rollback",
    "seed:materials": "npx tsx scripts/seed-materials.ts",
    "test:materials-api": "npx tsx scripts/test-materials-api.ts",
    "clean": "rimraf .next .turbo dist build",
    "clean:cache": "rimraf .next/cache",
    "analyze": "npm run build:analyze",
    "analyze:bundle": "node scripts/measure-bundle-size.js",
    "analyze:baseline": "node scripts/measure-bundle-size.js --save bundle-baseline.json",
    "analyze:compare": "node scripts/measure-bundle-size.js --compare bundle-baseline.json",
    "type-check": "tsc --noEmit",
    "test:load": "k6 run load-tests/k6/critical-endpoints.js",
    "test:load:api": "k6 run load-tests/k6/api-endpoints.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "playwright:codegen": "playwright codegen http://localhost:3000",
    "install:hero3d": "npm install @react-three/fiber@9.0.0-alpha.0 three --save"
  },
  "dependencies": {
    "node-cache": "^5.1.2",
    "@chatscope/chat-ui-kit-react": "^2.1.1",
    "@google-cloud/aiplatform": "^6.1.0",
    "@google-cloud/storage": "^7.18.0",
    "@googlemaps/markerclusterer": "^2.6.2",
    "@heroicons/react": "^2.2.0",
    "@hookform/resolvers": "^5.2.2",
    "@mintenance/ai-core": "file:../../packages/ai-core",
    "@mintenance/auth": "file:../../packages/auth",
    "@mintenance/design-tokens": "file:../../packages/design-tokens",
    "@mintenance/shared": "file:../../packages/shared",
    "@mintenance/shared-ui": "file:../../packages/shared-ui",
    "@mintenance/types": "file:../../packages/types",
    "@radix-ui/react-alert-dialog": "^1.0.5",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-radio-group": "^1.1.3",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.0.3",
    "@radix-ui/react-tabs": "^1.0.4",
    "@stripe/react-stripe-js": "^2.7.0",
    "@stripe/stripe-js": "^3.3.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.76.1",
    "@tanstack/react-query": "^5.90.0",
    "@tanstack/react-query-devtools": "^5.90.0",
    "@tremor/react": "^3.18.7",
    "@upstash/ratelimit": "^2.0.7",
    "@upstash/redis": "^1.30.0",
    "bcryptjs": "^3.0.3",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^3.6.0",
    "dompurify": "^3.1.2",
    "dotenv": "^17.2.3",
    "embla-carousel-react": "^8.6.0",
    "file-type": "^21.3.0",
    "framer-motion": "^12.23.24",
    "google-auth-library": "^9.9.0",
    "html2canvas": "^1.4.1",
    "jose": "^6.1.0",
    "jspdf": "^4.1.0",
    "lru-cache": "^11.2.4",
    "lucide-react": "^0.376.0",
    "next": "^16.0.4",
    "node-fetch": "^2.7.0",
    "onnxruntime-node": "^1.17.3",
    "onnxruntime-web": "^1.23.2",
    "openai": "^4.73.0",
    "otpauth": "^9.3.5",
    "qrcode": "^1.5.4",
    "react": "19.1.0",
    "react-confetti": "^6.4.0",
    "react-dom": "19.1.0",
    "react-dropzone": "^15.0.0",
    "react-hook-form": "^7.66.1",
    "react-hot-toast": "^2.6.0",
    "react-pdf": "^10.2.0",
    "recharts": "^2.12.7",
    "sharp": "^0.33.3",
    "stripe": "^15.4.0",
    "tailwind-merge": "^2.3.0",
    "twilio": "^5.10.7",
    "zod": "^3.23.4"
  },
  "devDependencies": {
    "@googlemaps/js-api-loader": "^1.16.6",
    "@next/bundle-analyzer": "^16.0.7",
    "@axe-core/playwright": "^4.10.0",
    "@playwright/test": "^1.58.0",
    "@tailwindcss/container-queries": "^0.1.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/google.maps": "^3.55.2",
    "@types/node": "^20.12.7",
    "@types/node-fetch": "^2.6.13",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.0.15",
    "@vitest/ui": "^4.0.15",
    "autoprefixer": "^10.4.22",
    "eslint": "^9",
    "eslint-config-next": "^16.0.3",
    "form-data": "^4.0.5",
    "happy-dom": "^20.0.11",
    "jsdom": "^24.0.0",
    "msw": "^2.12.4",
    "playwright": "^1.58.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.0.4",
    "vitest": "^4.0.15"
  },
  "overrides": {
    "minimatch": "^10.2.4"
  }
}
