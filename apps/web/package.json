    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.0.15",
    "@vitest/ui": "^4.0.15",
    "autoprefixer": "^10.4.23",
    "eslint": "^8.57.0",
    "eslint-config-next": "^16.0.3",
    "happy-dom": "^20.0.11",
    "jest": "^29.7.0",
    "msw": "^2.12.4",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.18",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.5",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.15"
  }
