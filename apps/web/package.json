    "dotenv": "^17.2.3",
    "embla-carousel-react": "^8.6.0",
    "file-type": "^21.3.0",
    "form-data": "^4.0.5",
    "framer-motion": "^12.23.24",
    "google-auth-library": "^9.9.0",
    "html2canvas": "^1.4.1",
    "jose": "^5.3.0",
    "jsdom": "^24.0.0",
    "jspdf": "^4.0.0",
    "lru-cache": "^11.2.4",
    "lucide-react": "^0.376.0",
    "next": "^16.0.4",
    "node-cache": "^5.1.2",
