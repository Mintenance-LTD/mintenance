{
  "name": "@mintenance/web",
  "version": "1.2.3",
  "private": true,
  "description": "Mintenance Web App (Next.js)",
  "scripts": {
    "dev": "next dev -p 3000 --webpack",
    "dev:turbo": "next dev -p 3000 --turbo",
    "build": "npm run clean && next build --webpack",
    "build:analyze": "npm run clean && ANALYZE=true next build --webpack",
    "build:turbo": "npm run clean && next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:run": "vitest run",
    "test:parallel": "vitest run --reporter=verbose",
    "test:debug": "vitest --inspect-brk --no-file-parallelism",
    "test:redis": "ts-node lib/redis-validator.ts",
    "migrate": "ts-node lib/migration-runner.ts",
    "migrate:status": "npm run migrate status",
    "migrate:apply": "npm run migrate apply",
    "migrate:rollback": "npm run migrate rollback",
    "clean": "rimraf .next .turbo dist build",
    "clean:cache": "rimraf .next/cache",
    "analyze": "npm run build:analyze",
    "analyze:bundle": "node scripts/measure-bundle-size.js",
    "analyze:baseline": "node scripts/measure-bundle-size.js --save bundle-baseline.json",
    "analyze:compare": "node scripts/measure-bundle-size.js --compare bundle-baseline.json",
    "type-check": "tsc --noEmit",
    "test:load": "k6 run load-tests/k6/critical-endpoints.js",
    "test:load:api": "k6 run load-tests/k6/api-endpoints.js"
  },
  "dependencies": {
    "@chatscope/chat-ui-kit-react": "^2.1.1",
    "@google-cloud/aiplatform": "^5.12.0",
    "@google-cloud/storage": "^7.17.3",
    "@google-cloud/vision": "^5.3.4",
    "@googlemaps/markerclusterer": "^2.6.2",
    "@heroicons/react": "^2.2.0",
    "@hookform/resolvers": "^5.2.2",
    "@mintenance/auth": "file:../../packages/auth",
    "@mintenance/design-tokens": "file:../../packages/design-tokens",
    "@mintenance/services": "file:../../packages/services",
    "@mintenance/shared": "file:../../packages/shared",
    "@mintenance/shared-ui": "file:../../packages/shared-ui",
    "@mintenance/types": "file:../../packages/types",
    "@radix-ui/react-alert-dialog": "^1.0.5",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-label": "^2.0.2",
