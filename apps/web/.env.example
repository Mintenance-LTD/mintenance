# Mintenance Web App Environment Variables
# Copy this file to .env.local and fill in your actual values
# Never commit .env.local to version control

# =============================================================================
# REQUIRED - Core Configuration
# =============================================================================

# Node Environment
# Options: development, production, test
# Default: development
NODE_ENV=development

# JWT Configuration (CRITICAL)
# Secret key for JWT signing - must be strong and random
# Minimum 64 characters for production security
# Generate with: openssl rand -base64 64
JWT_SECRET=your-jwt-secret-minimum-64-characters-here-generate-a-strong-random-secret

# =============================================================================
# REQUIRED - Supabase Configuration
# =============================================================================

# Supabase project URL
# Get this from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anonymous key (client-side)
# REQUIRED - Get this from your Supabase project settings > API > anon/public key
# IMPORTANT: This is the MOST CRITICAL missing environment variable
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Supabase service role key (server-side only)
# WARNING: Never expose this in client-side code
# Get this from your Supabase project settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# =============================================================================
# REQUIRED - Stripe Configuration
# =============================================================================

# Stripe secret key (server-side only)
# Must start with sk_test_ (test mode) or sk_live_ (production)
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key-here

# Stripe webhook signing secret
# Must start with whsec_
# Get from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret-here

# Stripe publishable key (client-side)
# Must start with pk_test_ (test mode) or pk_live_ (production)
# Get from: https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key-here

# =============================================================================
# REQUIRED IN PRODUCTION - Redis Configuration
# =============================================================================

# Upstash Redis URL for rate limiting
# Required in production for distributed rate limiting
# Get from: https://console.upstash.com/
UPSTASH_REDIS_REST_URL=https://your-redis-instance.upstash.io

# Upstash Redis token
# Required in production for distributed rate limiting
# Get from: https://console.upstash.com/
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token-here

# =============================================================================
# SECURITY - CORS Configuration (VULN-007 Fix)
# =============================================================================

# Allowed origins for cross-origin API requests (comma-separated)
# Production: Only add trusted domains
# Development: localhost origins are automatically added
# Example: https://staging.mintenance.com,https://preview.mintenance.com
# Default: Production domains from code (mintenance.com, www.mintenance.com, app.mintenance.com)
ALLOWED_ORIGINS=

# Enable/disable CORS validation
# true = strict whitelist-based validation (recommended for production)
# false = legacy behavior (not recommended)
# Default: true
ENABLE_CORS_VALIDATION=true

# CORS rollout percentage for gradual deployment (0-100)
# Used for phased rollout in production
# 0 = disabled, 10 = 10% of requests, 100 = all requests
# Default: 100
CORS_ROLLOUT_PERCENTAGE=100

# =============================================================================
# SECURITY - Session Timeout Configuration (VULN-009 Fix)
# =============================================================================

# Absolute session timeout in hours
# Maximum duration from original login before forced logout
# PCI DSS 8.2.4 requires ≤ 12 hours
# Default: 12
SESSION_ABSOLUTE_TIMEOUT_HOURS=12

# Idle session timeout in minutes
# Maximum duration of inactivity before forced logout
# PCI DSS 8.1.8 requires ≤ 15 minutes for high-security systems
# Default: 30 (less strict than PCI requirement for better UX)
SESSION_IDLE_TIMEOUT_MINUTES=30

# Enable/disable session timeout enforcement (VULN-009 Phase 3)
# CRITICAL: This controls whether session timeouts force logout or just log violations
#
# Enforcement Modes:
# - false (default): Soft enforcement - violations logged to security_events, requests proceed
# - true: Hard enforcement - violations force immediate logout (blacklist token + redirect/401)
#
# Deployment Strategy:
# 1. Week 1: Keep false, monitor security_events table for violation patterns
# 2. Week 2: Enable for internal team accounts only (test UX)
# 3. Week 3-4: Gradually enable in production (monitor support tickets)
# 4. Emergency rollback: Set to false immediately if issues detected
#
# Forced Logout Behavior:
# - Page requests (/dashboard): Redirect to /login (or /admin/login for admin routes)
# - API requests (/api/*): Return JSON 401 with timeout details
# - Token blacklisted to prevent reuse (defense in depth)
#
# Recommended: false for development/staging, true for production after testing
# Default: false
ENFORCE_SESSION_TIMEOUTS=false

# =============================================================================
# OPTIONAL - AI Service Configuration
# =============================================================================

# OpenAI API key for GPT-4 Vision and embeddings (server-side only)
# Required for AI assessment features
# Must start with sk- or sk-proj-
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# =============================================================================
# OPTIONAL - Roboflow Configuration
# =============================================================================

# Roboflow API key for building damage detection
# Get from: https://roboflow.com/
ROBOFLOW_API_KEY=your-roboflow-api-key-here

# Roboflow model ID
# Default: building-defect-detection-7-ks0im
ROBOFLOW_MODEL_ID=building-defect-detection-7-ks0im

# Roboflow model version (Building Defect Detection 7 4 = best mAP@50)
# Default: 4
ROBOFLOW_MODEL_VERSION=4

# Roboflow API timeout in milliseconds
# Default: 10000
ROBOFLOW_TIMEOUT_MS=10000

# =============================================================================
# OPTIONAL - Google Maps Configuration
# =============================================================================

# Google Maps API key for geocoding and map display (SERVER-SIDE ONLY)
# SECURITY: This key is NEVER exposed to the client
# Used by /api/geocode-proxy and /api/maps-static endpoints
# Required for location features
# Get from: https://console.cloud.google.com/apis/credentials
#
# IMPORTANT:
# - Do NOT use NEXT_PUBLIC prefix (that exposes the key to client)
# - Enable only: Geocoding API, Maps Static API
# - Set IP restrictions to your server IPs
# - Rotate immediately if previously exposed client-side
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# =============================================================================
# OPTIONAL - AWS Configuration
# =============================================================================

# AWS access key for Rekognition
AWS_ACCESS_KEY_ID=your-aws-access-key-id-here

# AWS secret access key
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key-here

# AWS region
# Default: us-east-1
AWS_REGION=us-east-1

# =============================================================================
# OPTIONAL - Google Cloud Configuration
# =============================================================================

# Google Cloud API key for Vision API
GOOGLE_CLOUD_API_KEY=your-google-cloud-api-key-here

# =============================================================================
# OPTIONAL - Weather API Configuration
# =============================================================================

# OpenWeatherMap API key for weather forecasts
# Required for intelligent job scheduling and weather-based auto-rescheduling
# Sign up at: https://openweathermap.org/api
# Free tier: 1,000 calls/day, 60 calls/minute
OPENWEATHER_API_KEY=your-openweathermap-api-key-here

# =============================================================================
# OPTIONAL - Monitoring & Analytics
# =============================================================================

# Sentry DSN for error tracking
# Get from: https://sentry.io/settings/
SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id

# =============================================================================
# OPTIONAL - SAM 3 Segmentation Service
# =============================================================================

# SAM 3 Python microservice URL
# Default: http://localhost:8001
SAM3_SERVICE_URL=http://localhost:8001

# Enable SAM 3 segmentation (text-prompted damage detection)
# Default: false (set to true to enable)
ENABLE_SAM3_SEGMENTATION=false

# Hugging Face token for model downloads
# Required if SAM 3 model needs to be downloaded
# Get from: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# SAM model version tracking
# Default: 3
SAM_MODEL_VERSION=3

# Gradual rollout percentage (0-100)
# Controls what percentage of requests use SAM 3
# Default: 0 (disabled), set to 10 for 10% rollout
SAM3_ROLLOUT_PERCENTAGE=0

# SAM 3 segmentation timeout in milliseconds
# Default: 30000 (30 seconds)
SAM3_TIMEOUT_MS=30000

# =============================================================================
# OPTIONAL - Application Configuration
# =============================================================================

# Application public URL
# Used for generating absolute URLs (e.g., email links)
# Example: https://mintenance.co.uk
NEXT_PUBLIC_APP_URL=http://localhost:3000
