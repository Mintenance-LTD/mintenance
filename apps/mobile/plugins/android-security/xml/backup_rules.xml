<?xml version="1.0" encoding="utf-8"?>
<!--
  Backup Rules - defense-in-depth for when allowBackup is re-enabled.

  With android:allowBackup="false" on <application>, these rules are
  not strictly required. They are retained as belt-and-braces protection
  in case allowBackup is ever toggled back on (e.g., for user-initiated
  data migration). The following are NEVER included in any backup:

  - RKStorage/         - React Native AsyncStorage (JWT + query cache)
  - secure_store.xml   - expo-secure-store fallback sharedPreferences
  - mintenance_local.db - local SQLite (jobs, messages, bids)
  - sync_state         - offline queue state

  Source of truth: apps/mobile/plugins/android-security/xml/.
  This file is COPIED into android/app/src/main/res/xml/ by the
  android-security Expo config plugin on every `expo prebuild`.
-->
<full-backup-content>
  <exclude domain="file" path="RKStorage/"/>
  <exclude domain="sharedpref" path="secure_store.xml"/>
  <exclude domain="database" path="mintenance_local.db"/>
  <exclude domain="database" path="mintenance_local.db-journal"/>
  <exclude domain="database" path="mintenance_local.db-wal"/>
  <exclude domain="database" path="mintenance_local.db-shm"/>
  <exclude domain="file" path="sync_state/"/>
</full-backup-content>
