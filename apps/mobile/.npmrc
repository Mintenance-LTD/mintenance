# NPM Configuration for Mobile App
# Ensures proper dependency resolution during EAS Build

# Use exact versions (no caret/tilde ranges that might resolve incorrectly)
save-exact=false

# Required for React 19 compatibility — matches root .npmrc setting
# Many packages still declare peerDeps for react ^18.x; react 19 would fail strict peer checks
legacy-peer-deps=true

# Do not enforce engine constraints — EAS uses its own Node version management
engine-strict=false

