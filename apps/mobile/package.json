{
  "name": "@mintenance/mobile",
  "version": "1.2.4",
  "private": true,
  "description": "Mintenance Mobile App (React Native/Expo)",
  "scripts": {
    "start": "expo start",
    "dev": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "eas build",
    "build:android": "eas build --platform android",
    "build:android:apk": "eas build --platform android --profile preview",
    "build:android:internal": "eas build --platform android --profile internal",
    "build:android:dev": "eas build --platform android --profile development",
    "build:android:staging": "eas build --platform android --profile staging",
    "build:ios": "eas build --platform ios",
    "submit": "eas submit",
    "test": "npx jest",
    "test:parallel": "npx jest --maxWorkers=4",
    "test:coverage": "npx jest --coverage",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "type-check": "tsc --noEmit",
    "clean": "rimraf .expo node_modules",
    "align:expo": "expo install",
    "align:rn": "expo install react-native",
    "align:deps": "expo install react-native react-native-reanimated react-native-screens react-native-safe-area-context",
    "validate:env": "node ../../scripts/validate-credentials.js",
    "setup:eas-env": "node set-eas-env.js",
    "analyze": "npx expo export --platform android --output-dir ./dist && du -sh ./dist",
    "analyze:ios": "npx expo export --platform ios --output-dir ./dist && du -sh ./dist",
    "check:performance": "node ../../scripts/check-performance-budgets.js mobile",
    "prebuild": "npm run validate:env",
    "prestart": "npm run validate:env",
    "predev": "npm run validate:env",
    "postinstall": "cd ../.. && npm run build:packages --if-present"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@mintenance/ai-core": "file:../../packages/ai-core",
    "@mintenance/api-client": "file:../../packages/api-client",
    "@mintenance/design-tokens": "file:../../packages/design-tokens",
    "@mintenance/services": "file:../../packages/services",
    "@mintenance/types": "file:../../packages/types",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native-picker/picker": "2.11.1",
    "@react-native/babel-plugin-codegen": "^0.81.0",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/drawer": "^7.1.1",
    "@react-navigation/native": "^7.0.14",
    "@react-navigation/stack": "^7.2.10",
    "@sentry/react-native": "^7.8.0",
    "@stripe/stripe-react-native": "0.57.3",
    "@supabase/supabase-js": "^2.50.0",
    "@tanstack/react-query": "^5.90.0",
    "expo": "~54.0.0",
    "expo-application": "~7.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.12",
    "expo-crypto": "~15.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.10",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.0",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-local-authentication": "~17.0.8",
    "expo-location": "~19.0.8",
    "expo-network": "~8.0.8",
    "expo-notifications": "~0.32.15",
    "expo-router": "~6.0.21",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "~16.0.0",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-updates": "~29.0.15",
    "expo-web-browser": "~15.0.10",
    "i18next": "^25.8.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^15.4.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-localize": "^3.2.2",
    "react-native-maps": "1.20.1",
    "react-native-chart-kit": "^6.12.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-svg": "15.12.1",
    "react-native-screens": "~4.16.0",
    "react-native-swiper-flatlist": "^3.2.5",
    "react-native-web": "^0.21.0",
    "sentry-expo": "^7.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "~29.5.14",
    "@types/react": "~19.1.10",
    "@types/react-test-renderer": "^19.0.0",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~10.0.0",
    "jest": "~29.7.0",
    "jest-expo": "~54.0.0",
    "react-native-worklets-core": "^1.6.2",
    "react-test-renderer": "19.2.3",
    "typescript": "~5.9.0"
  },
  "overrides": {
    "react-native": "0.81.5",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  }
}
