{
  "cli": {
    "version": ">= 16.17.4",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "node": "20.19.4",
      "cache": {
        "key": "development",
        "disabled": false,
        "paths": ["node_modules"]
      },
      "android": {
        "gradleCommand": ":app:assembleDebug",
        "buildType": "apk",
        "image": "ubuntu-22.04-jdk-17-ndk-r26b"
      },
      "ios": {
        "buildConfiguration": "Debug",
        "simulator": true
      },
      "env": {
        "NODE_ENV": "development",
        "JAVA_HOME": "/usr/lib/jvm/java-17-openjdk-amd64",
        "EXPO_PUBLIC_SUPABASE_URL": "${EXPO_PUBLIC_SUPABASE_URL}",
        "EXPO_PUBLIC_SUPABASE_ANON_KEY": "${EXPO_PUBLIC_SUPABASE_ANON_KEY}",
        "EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY": "${EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY}",
        "EXPO_PUBLIC_USE_MOCK": "false"
      },
      "channel": "development"
    },
    "stable": {
      "distribution": "internal",
      "node": "20.19.4",
      "cache": {
        "key": "stable",
        "disabled": false,
        "paths": ["node_modules"]
      },
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease",
        "image": "ubuntu-22.04-jdk-17-ndk-r26b"
      },
      "ios": {
        "buildConfiguration": "Release"
      },
      "env": {
        "NODE_ENV": "production",
        "EXPO_USE_FAST_RESOLVER": "1",
        "EXPO_USE_HERMES": "1",
        "EXPO_OPTIMIZE": "1",
        "JAVA_HOME": "/usr/lib/jvm/java-17-openjdk-amd64",
        "EXPO_PUBLIC_SUPABASE_URL": "${EXPO_PUBLIC_SUPABASE_URL}",
        "EXPO_PUBLIC_SUPABASE_ANON_KEY": "${EXPO_PUBLIC_SUPABASE_ANON_KEY}",
        "EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY": "${EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY}",
        "EXPO_PUBLIC_USE_MOCK": "false"
      },
      "channel": "stable"
    },
    "staging": {
      "distribution": "internal",
      "node": "20.19.4",
      "cache": {
        "key": "staging",
        "disabled": false,
        "paths": ["node_modules"]
      },
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease",
        "image": "ubuntu-22.04-jdk-17-ndk-r26b"
      },
      "ios": {
        "buildConfiguration": "Release"
      },
      "env": {
        "NODE_ENV": "staging",
        "JAVA_HOME": "/usr/lib/jvm/java-17-openjdk-amd64",
        "EXPO_PUBLIC_SUPABASE_URL": "${EXPO_PUBLIC_SUPABASE_URL}",
        "EXPO_PUBLIC_SUPABASE_ANON_KEY": "${EXPO_PUBLIC_SUPABASE_ANON_KEY}",
        "EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY": "${EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY}",
        "EXPO_PUBLIC_USE_MOCK": "false"
      },
      "channel": "staging"
    },
    "preview": {
      "distribution": "internal",
      "node": "20.19.4",
      "cache": {
        "key": "preview",
        "disabled": false,
        "paths": ["node_modules"]
      },
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease",
        "image": "ubuntu-22.04-jdk-17-ndk-r26b"
      },
      "ios": {
        "buildConfiguration": "Release"
      },
      "env": {
        "NODE_ENV": "production",
        "EXPO_USE_FAST_RESOLVER": "1",
        "EXPO_USE_HERMES": "1",
        "EXPO_OPTIMIZE": "1",
        "EXPO_PUBLIC_SUPABASE_URL": "${EXPO_PUBLIC_SUPABASE_URL}",
        "EXPO_PUBLIC_SUPABASE_ANON_KEY": "${EXPO_PUBLIC_SUPABASE_ANON_KEY}",
        "EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY": "${EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY}",
        "EXPO_PUBLIC_USE_MOCK": "false"
      },
      "channel": "preview"
    },
    "internal": {
      "distribution": "internal",
      "node": "20.19.4",
      "cache": {
        "key": "internal",
        "disabled": false,
        "paths": ["node_modules"]
      },
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease",
        "image": "ubuntu-22.04-jdk-17-ndk-r26b"
      },
      "ios": {
        "buildConfiguration": "Release"
      },
      "env": {
        "NODE_ENV": "production",
        "EXPO_USE_FAST_RESOLVER": "1",
        "EXPO_USE_HERMES": "1",
        "EXPO_OPTIMIZE": "1",
        "JAVA_HOME": "/usr/lib/jvm/java-17-openjdk-amd64",
        "EXPO_PUBLIC_SUPABASE_URL": "${EXPO_PUBLIC_SUPABASE_URL}",
        "EXPO_PUBLIC_SUPABASE_ANON_KEY": "${EXPO_PUBLIC_SUPABASE_ANON_KEY}",
        "EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY": "${EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY}",
        "EXPO_PUBLIC_USE_MOCK": "false"
      },
      "channel": "internal"
    },
    "production": {
      "node": "20.19.4",
      "cache": {
        "key": "production",
        "disabled": false,
        "paths": ["node_modules"]
      },
      "android": {
        "buildType": "app-bundle",
        "gradleCommand": ":app:bundleRelease",
        "image": "ubuntu-22.04-jdk-17-ndk-r26b"
      },
      "ios": {
        "buildConfiguration": "Release"
      },
      "env": {
        "NODE_ENV": "production",
        "JAVA_HOME": "/usr/lib/jvm/java-17-openjdk-amd64",
        "EXPO_PUBLIC_SUPABASE_URL": "${EXPO_PUBLIC_SUPABASE_URL}",
        "EXPO_PUBLIC_SUPABASE_ANON_KEY": "${EXPO_PUBLIC_SUPABASE_ANON_KEY}",
        "EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY": "${EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY}",
        "EXPO_PUBLIC_USE_MOCK": "false"
      },
      "channel": "production"
    },
    "production-store": {
      "distribution": "store",
      "node": "20.19.4",
      "cache": {
        "key": "production-store",
        "disabled": false,
        "paths": ["node_modules"]
      },
      "android": {
        "buildType": "app-bundle",
        "gradleCommand": ":app:bundleRelease",
        "image": "ubuntu-22.04-jdk-17-ndk-r26b"
      },
      "ios": {
        "buildConfiguration": "Release"
      },
      "env": {
        "NODE_ENV": "production",
        "JAVA_HOME": "/usr/lib/jvm/java-17-openjdk-amd64",
        "EXPO_PUBLIC_SUPABASE_URL": "${EXPO_PUBLIC_SUPABASE_URL}",
        "EXPO_PUBLIC_SUPABASE_ANON_KEY": "${EXPO_PUBLIC_SUPABASE_ANON_KEY}",
        "EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY": "${EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY}",
        "EXPO_PUBLIC_USE_MOCK": "false"
      },
      "channel": "production"
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./credentials/play-store-service-account.json",
        "track": "production",
        "releaseStatus": "draft"
      },
      "ios": {
        "appleId": "${APPLE_ID_EMAIL}",
        "ascAppId": "${ASC_APP_ID}",
        "appleTeamId": "${APPLE_TEAM_ID}"
      }
    }
  }
}
