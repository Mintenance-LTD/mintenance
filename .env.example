# Mintenance Monorepo Environment Variables Template
# Copy this file to .env and fill in your actual values

# =============================================================================
# CRITICAL SECURITY VARIABLES (REQUIRED FOR ALL ENVIRONMENTS)
# =============================================================================

# JWT Secret for web app authentication (MUST be 32+ characters)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-here-minimum-32-characters-use-openssl-rand-base64-32

# Node environment
NODE_ENV=development

# =============================================================================
# SUPABASE CONFIGURATION (REQUIRED FOR BOTH APPS)
# =============================================================================

# Supabase URL (public)
NEXT_PUBLIC_SUPABASE_URL=https://[YOUR_PROJECT_ID].supabase.co

# Supabase anonymous key (public)
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Supabase service role key (SERVER-SIDE ONLY - for web app)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# =============================================================================
# STRIPE CONFIGURATION (PAYMENT PROCESSING)
# =============================================================================

# Stripe publishable key (public)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key-here

# Stripe secret key (SERVER-SIDE ONLY - for web app)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key-here

# =============================================================================
# REDIS CONFIGURATION (RATE LIMITING & CACHING)
# =============================================================================

# Upstash Redis (Recommended for production)
# Get these from https://console.upstash.com/
UPSTASH_REDIS_REST_URL=https://your-redis-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token-here

# Rate Limiting Configuration
# Whitelist IPs that bypass rate limiting (comma-separated)
RATE_LIMIT_WHITELIST_IPS=

# Internal service tokens for service-to-service communication (comma-separated)
INTERNAL_SERVICE_TOKENS=

# =============================================================================
# APP CONFIGURATION
# =============================================================================

# App name and version
EXPO_PUBLIC_APP_NAME=Mintenance
EXPO_PUBLIC_APP_VERSION=1.2.3
EXPO_PUBLIC_ENVIRONMENT=development

# API Configuration
EXPO_PUBLIC_API_BASE_URL=https://your-project.supabase.co/rest/v1
EXPO_PUBLIC_API_TIMEOUT=30000

# =============================================================================
# HYBRID INFERENCE SYSTEM (AI/ML CONFIGURATION)
# =============================================================================

# Enable hybrid inference routing (internal YOLO model + GPT-4 fallback)
# Set to 'true' to activate cost-saving ML models
USE_HYBRID_INFERENCE=true

# YOLO Model Configuration
YOLO_MODEL_PATH=best_model_final_v2.onnx
YOLO_DATA_YAML_PATH=./yolo_dataset_full/data.yaml

# Model Performance Thresholds
# Confidence threshold for using internal model (0-1)
# Lower = more internal usage = lower costs, Higher = more GPT-4 usage = higher accuracy
HYBRID_CONFIDENCE_THRESHOLD=0.75

# Enable learned features (requires training data)
USE_LEARNED_FEATURES=false

# Enable TITANS memory enhancement (experimental)
USE_TITANS=false

# Mint AI VLM: use in-house VLM for building assessment generator (Phase 4; stub uses GPT-4o when true)
USE_MINT_AI_VLM=false

# Web app URL (for production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable/disable features
EXPO_PUBLIC_ENABLE_BIOMETRIC_AUTH=true
EXPO_PUBLIC_ENABLE_PUSH_NOTIFICATIONS=true
EXPO_PUBLIC_ENABLE_ANALYTICS=false
EXPO_PUBLIC_ENABLE_CRASH_REPORTING=false

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================

# E2E / Playwright: Set to true ONLY when running Playwright tests (playwright sets this).
# Leave false or unset for normal dev; otherwise /api/auth/session returns a mock user
# and you will see test-homeowner@example.com instead of your real account on Settings.
# PLAYWRIGHT_TEST=false

# Logging
EXPO_PUBLIC_LOG_LEVEL=debug
EXPO_PUBLIC_ENABLE_CONSOLE_LOGS=true

# Performance
EXPO_PUBLIC_ENABLE_METRO_CACHE=true
EXPO_PUBLIC_ENABLE_NATIVE_OPTIMIZATIONS=true

# Build settings
EXPO_PUBLIC_BUILD_NUMBER=1
EXPO_USE_FAST_RESOLVER=1
EXPO_USE_HERMES=true


# Roboflow Configuration
# ROBOFLOW_MODEL_VERSION is the version number in the Roboflow detect URL (e.g., /1, /2, /3).
# Update this value whenever a new model version is trained and deployed in Roboflow.
# Sentry DSN (for error tracking and performance monitoring)
# EXPO_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# =============================================================================
# SECURITY NOTES
# =============================================================================
# 1. NEVER commit .env files with real credentials to version control
# 2. Use environment-specific .env files (.env.development, .env.production)
# 3. Server-side keys (SERVICE_ROLE, SECRET_KEY, OPENAI) must NEVER be exposed to clients
# 4. Rotate all keys immediately if accidentally committed
# 5. Use secrets managers (AWS Secrets Manager, Vercel Env, etc.) in production