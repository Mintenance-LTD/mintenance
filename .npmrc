# NPM Configuration for Mintenance Monorepo

# KEEP: Required for React 19 + React Native 0.81 compatibility.
# 18 Babel/Jest packages declare outdated peerDeps for @babel/core.
# Tested 2026-04-07: removing this causes npm install to fail with 18 ERESOLVE errors.
# Re-evaluate when babel-preset-jest and babel-preset-current-node-syntax update.
legacy-peer-deps=true

# --- Supply Chain Security ---

# Prevent dependency confusion: @mintenance packages resolve only from local workspaces.
# If someone registers @mintenance on public npm, this ensures it's never fetched.
@mintenance:registry=https://registry.npmjs.org/

# Block arbitrary install scripts from running during npm install.
# This prevents compromised packages from executing code at install time.
ignore-scripts=true

# Allowlist: packages that legitimately need postinstall/install scripts.
# These download platform-specific native binaries and are well-known trusted packages.
# Run their scripts explicitly after install: npm rebuild <package>
# Or use the lifecycle script in package.json "prepare" to rebuild them.
#
# Trusted packages requiring scripts:
#   esbuild, sharp, @sentry/cli, onnxruntime-node, protobufjs,
#   core-js, fsevents (macOS only), msw, detox (test-only)
