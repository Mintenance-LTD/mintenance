{
  "name": "@mintenance/api-services",
  "version": "1.0.0",
  "description": "Business logic and services for Mintenance API",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
